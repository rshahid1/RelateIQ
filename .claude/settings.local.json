{
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm install)",
      "Bash(export PATH=\"$HOME/local/node/bin:$PATH\" && npm run dev)",
      "Bash(export PATH=\"$HOME/local/node/bin:$PATH\" && npm run build)",
      "Bash(export PATH=\"$HOME/local/node/bin:$PATH\" && npm install)",
      "Bash(npm create *)",
      "Bash(ls /opt/pkg/env/active/bin/ | grep -E \"node|npm|bun|yarn|pnpm\" 2>/dev/null)",
      "Bash(ls /opt/pmk/env/global/bin/ 2>/dev/null | head -20)",
      "Bash(curl -fsSL https://deb.nodesource.com/setup_lts.x)",
      "Bash(curl -fsSL \"https://nodejs.org/dist/v20.18.0/node-v20.18.0-darwin-arm64.tar.gz\" -o /tmp/node.tar.gz)",
      "Bash(wait)",
      "Read(//private/tmp/**)",
      "Bash(mkdir -p ~/local/node)",
      "Bash(tar -xzf /tmp/node.tar.gz -C ~/local/node --strip-components=1)",
      "Bash(~/local/node/bin/node --version)",
      "Bash(~/local/node/bin/npm --version)"
    ]
  }
}
